# Copy this file to .env and paste in your own values.
# .env is git-ignored — it never gets committed or pushed, and the test
# scripts only ever print rate results, never your keys.
#
# You only need API credentials for the three carriers whose pages block us:
# UPS, FedEx, Purolator. Canada Post and Canpar already read for free and
# need nothing here.

# --- ShipStation API (test this FIRST — one key, you already have the account) ---
# ShipStation -> Settings -> Account -> API Settings -> generate a v2 API key.
SHIPSTATION_API_KEY=

# --- FedEx Rate API ---
# developer.fedex.com -> create a project -> subscribe to "Rate" (Rates and
# Transit Times) -> move the project to PRODUCTION (sandbox returns fake rates).
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
FEDEX_ACCOUNT=
FEDEX_BASE=https://apis.fedex.com

# --- UPS Rating API ---
# developer.ups.com -> create an app -> add your UPS account number ->
# enable the "Rating" product. OAuth client credentials.
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT=
UPS_BASE=https://onlinetools.ups.com

# --- Purolator E-Ship Web Services ---
# Request developer access via your Purolator account rep / the E-Ship Web
# Services Toolkit. You get a Production Key and Password tied to your account.
# This one can take a few business days to approve — start it first.
PUROLATOR_KEY=
PUROLATOR_PASSWORD=
PUROLATOR_ACCOUNT=
PUROLATOR_BASE=https://devwebservices.purolator.com
